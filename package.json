{
  "name": "pixvec",
  "version": "2.5.0",
  "description": "Pixvec professional pixel art environment",
  "author": "Gadex Labs",
  "main": "app.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.gadexlabs.pixvec",
    "publish": null,
    "productName": "PiXVec",
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.0.0"
  }
}
